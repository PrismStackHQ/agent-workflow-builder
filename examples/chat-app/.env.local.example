# Agent Workflow Platform API
AGENT_WORKFLOW_API_KEY=ws_your_api_key_here
AGENT_WORKFLOW_API_URL=http://localhost:3001/api/v1
AGENT_WORKFLOW_WS_URL=ws://localhost:3002/ws

# End user ID (Organisation A's internal user identifier)
END_USER_ID=demo-user-002

# Nango configuration (server-side only — secrets stay off frontend)
NANGO_SECRET_KEY=your-nango-secret-key
NANGO_HOST=https://api.nango.dev

# Public env vars (available in browser)
NEXT_PUBLIC_WS_URL=ws://localhost:3002/ws
NEXT_PUBLIC_API_KEY=ws_your_api_key_here
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_END_USER_ID=demo-user-002
NEXT_PUBLIC_NANGO_HOST=https://api.nango.dev
