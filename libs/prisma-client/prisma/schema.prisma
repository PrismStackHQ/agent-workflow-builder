generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id          String    @id @default(uuid())
  name        String
  orgEmail    String    @unique
  firebaseUid String?   @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspaces Workspace[]

  @@index([orgEmail])
  @@index([firebaseUid])
}

model Workspace {
  id        String    @id @default(uuid())
  orgId     String
  name      String
  apiKey    String    @unique @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  organization            Organization           @relation(fields: [orgId], references: [id])
  config                  CustomerConfig?
  connectionRefs          ConnectionRef[]
  agentDefinitions        AgentDefinition[]
  availableIntegrations   AvailableIntegration[]
  toolRegistryEntries     ToolRegistryEntry[]
  proxyActionDefinitions  ProxyActionDefinition[]

  @@index([apiKey])
  @@index([orgId])
}

enum IntegrationProvider {
  NANGO
  UNIPILE
  MERGE
}

model CustomerConfig {
  id                       String               @id @default(uuid())
  workspaceId              String               @unique
  integrationProvider      IntegrationProvider?
  connectionEndpointUrl    String?
  connectionEndpointApiKey String?
  ragEndpointUrl           String?
  ragEndpointApiKey        String?
  lastSyncedAt             DateTime?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])
}

model AvailableIntegration {
  id                  String              @id @default(uuid())
  workspaceId         String
  integrationProvider IntegrationProvider
  providerKey         String
  displayName         String
  logoUrl             String?
  rawMetadata         Json?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, integrationProvider, providerKey])
  @@index([workspaceId])
}

enum ConnectionStatus {
  PENDING
  OAUTH_REQUIRED
  READY
  FAILED
}

model ConnectionRef {
  id                String           @id @default(uuid())
  workspaceId       String
  provider          String
  externalRefId     String
  connectionId      String?
  metadata          Json?
  status            ConnectionStatus @default(PENDING)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, provider, externalRefId])
  @@index([workspaceId, provider])
  @@index([workspaceId, externalRefId])
}

enum AgentStatus {
  DRAFT
  WAITING_CONNECTIONS
  READY
  SCHEDULED
  PAUSED
  FAILED
}

model AgentDefinition {
  id                     String      @id @default(uuid())
  workspaceId            String
  name                   String
  naturalLanguageCommand String
  endUserId              String?
  scheduleCron           String?
  triggerType            String      @default("cron")
  requiredConnections    Json        @default("[]")
  steps                  Json        @default("[]")
  instructions           String?     @db.Text
  planDescription        String?     @db.Text
  status                 AgentStatus @default(DRAFT)
  k8sCronJobName         String?
  k8sNamespace           String?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  workspace Workspace    @relation(fields: [workspaceId], references: [id])
  runs      AgentRun[]

  @@index([workspaceId])
  @@index([workspaceId, endUserId])
  @@index([status])
}

enum RunStatus {
  PENDING
  RUNNING
  PAUSED
  SUCCEEDED
  FAILED
  CANCELLED
}

model AgentRun {
  id                String    @id @default(uuid())
  agentId           String
  startedAt         DateTime?
  endedAt           DateTime?
  status            RunStatus @default(PENDING)
  stepsCompleted    Int       @default(0)
  logsPointer       String?
  errorMessage      String?
  endUserConnectionId String?
  pausedAt          DateTime?
  pausedAtStepIndex Int?
  pauseReason       String?
  pauseMetadata     Json?
  parentRunId       String?
  depth             Int       @default(0)
  resumedAt         DateTime?
  createdAt         DateTime  @default(now())

  agent AgentDefinition @relation(fields: [agentId], references: [id])

  @@index([agentId, createdAt(sort: Desc)])
  @@index([status])
}

model ToolRegistryEntry {
  id                  String              @id @default(uuid())
  workspaceId         String
  integrationProvider IntegrationProvider
  integrationKey      String
  actionName          String
  displayName         String
  description         String?
  inputSchema         Json?
  outputSchema        Json?
  rawDefinition       Json?
  syncedAt            DateTime            @default(now())
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, integrationProvider, actionName])
  @@index([workspaceId, integrationKey])
}

model ProxyActionDefinition {
  id                String   @id @default(uuid())
  workspaceId       String
  providerConfigKey String
  actionName        String
  actionType        String
  displayName       String
  description       String?
  method            String
  endpoint          String

  paramsConfig      Json?
  bodyConfig        Json?
  headersConfig     Json?
  responseConfig    Json?
  postProcessConfig Json?

  transformerName   String?

  inputSchema       Json?
  outputSchema      Json?
  isEnabled         Boolean  @default(true)
  isDefault         Boolean  @default(false)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, providerConfigKey, actionName])
  @@index([workspaceId, providerConfigKey])
  @@index([workspaceId, isEnabled])
}
